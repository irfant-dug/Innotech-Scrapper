dnf install google-chrome-stable -y
useradd innotech_scraper
mkdir -p /opt/innotech_scraper

install -o innotech_scraper -g innotech_scraper innotechscraper.py /opt/innotech_scraper/
install -o innotech_scraper -g innotech_scraper innotechscraper_api.py /opt/innotech_scraper/
install -o innotech_scraper -g innotech_scraper dotenv /opt/innotech_scraper/.env
install -o root -g root systemd/innotech_scraper_api.service /etc/systemd/system/
install -o root -g root systemd/innotech_scraper.timer /etc/systemd/system/
install -o root -g root systemd/innotech_scraper.service /etc/systemd/system/

python3 -m venv /opt/innotech_scraper/selenium-env
mkdir -p /opt/innotech_scraper/chrome
wget -P /opt/innotech_scraper/chrome https://storage.googleapis.com/chrome-for-testing-public/146.0.7680.31/linux64/chrome-linux64.zip && \
unzip -o /opt/innotech_scraper/chrome/chrome-linux64.zip -d /opt/innotech_scraper/chrome/
wget -P /opt/innotech_scraper/chrome https://storage.googleapis.com/chrome-for-testing-public/146.0.7680.31/linux64/chromedriver-linux64.zip && \
unzip -o /opt/innotech_scraper/chrome/chromedriver-linux64.zip -d /opt/innotech_scraper/chrome/
rm -f /opt/innotech_scraper/chrome/chrome-linux64.zip
rm -f /opt/innotech_scraper/chrome/chromedriver-linux64.zip

chown innotech_scraper:innotech_scraper /opt/innotech_scraper -R
su - innotech_scraper -c "restorecon -Rv /opt/innotech_scraper" 
/opt/innotech_scraper/selenium-env/bin/python -m pip install --upgrade pip
/opt/innotech_scraper/selenium-env/bin/python -m pip install selenium python-dotenv beautifulsoup4 fastapi[standard]
